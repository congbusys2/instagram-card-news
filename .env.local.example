# 이 파일을 복사해 .env.local 로 저장한 뒤 값을 채우세요.
# .env.local 은 Git에 올라가지 않습니다.

# 다른 Google 계정으로 쓰려면:
# 1) 브라우저에서 해당 계정으로 https://aistudio.google.com/apikey 접속
# 2) Create API key 로 새 키 발급
# 3) 아래 값을 그 키로 교체하고 dev 서버를 한 번 재시작

GEMINI_API_KEY=

# 선택: Gemini API 베이스 URL (비우면 Google 기본 엔드포인트 사용)
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

